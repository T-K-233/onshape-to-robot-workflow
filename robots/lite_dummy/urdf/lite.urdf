        <mesh filename="../meshes/neck_yaw_visual.stl"/>
      </geometry>
      <material name="neck_yaw_parts_material">
        <color rgba="0.933333 0.933333 0.933333 1"/>
      </material>
    </visual>
  </link>
  <!-- Link neck_roll -->
  <link name="neck_roll">
    <inertial>
      <origin xyz="0 0.03 0" rpy="0 0 0"/>
      <mass value="0.0779115"/>
      <inertia ixx="1.55823e-05" ixy="-0" ixz="-0" iyy="2.40227e-05" iyz="0" izz="2.40227e-05"/>
    </inertial>
    <!-- Part neck_roll_parts -->
    <visual>
      <origin xyz="0 0.03 0" rpy="-1.5708 -1.5708 0"/>
      <geometry>
        <mesh filename="../meshes/neck_roll_visual.stl"/>
      </geometry>
      <material name="neck_roll_parts_material">
        <color rgba="0.933333 0.933333 0.933333 1"/>
      </material>
    </visual>
  </link>
  <!-- Link head -->
  <link name="head">
    <inertial>
      <origin xyz="0.00134973 0.0584846 -5.43e-10" rpy="0 0 0"/>
      <mass value="4.7098"/>
      <inertia ixx="0.0192792" ixy="-0.00180799" ixz="-7.2e-11" iyy="0.0157942" iyz="-3e-11" izz="0.0201095"/>
    </inertial>
    <!-- Part head_parts -->
    <collision>
      <origin xyz="-0 0.05 -0" rpy="-1.5708 -1.5708 0"/>
      <geometry>
        <cylinder length="0.03" radius="0.09"/>
      </geometry>
    </collision>
    <visual>
      <origin xyz="0.00134973 0.0584846 -5.43e-10" rpy="1.5708 -0 -3.14159"/>
      <geometry>
        <mesh filename="../meshes/head_visual.stl"/>
      </geometry>
      <material name="head_parts_material">
        <color rgba="0.933333 0.933333 0.933333 1"/>
      </material>
    </visual>
  </link>
  <!-- Joint from neck_roll to head -->
  <joint name="neck_pitch" type="revolute">
    <origin xyz="0 0.03 -0" rpy="0 1.5708 0"/>
    <parent link="neck_roll"/>
    <child link="head"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" velocity="100" lower="-0.523599" upper="0.523599"/>
    <joint_properties friction="0.1"/>
  </joint>
  <!-- Joint from neck_yaw to neck_roll -->
  <joint name="neck_roll" type="revolute">
    <origin xyz="0 -0 0.03" rpy="1.5708 0 1.5708"/>
    <parent link="neck_yaw"/>
    <child link="neck_roll"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" velocity="100" lower="-0.523599" upper="0.523599"/>
    <joint_properties friction="0.1"/>
  </joint>
  <!-- Joint from chest to neck_yaw -->
  <joint name="neck_yaw" type="revolute">
    <origin xyz="-0.01 -0 0.45" rpy="0 -0 -0"/>
    <parent link="chest"/>
    <child link="neck_yaw"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" velocity="100" lower="-0.785398" upper="0.785398"/>
    <joint_properties friction="0.1"/>
  </joint>
</robot>
